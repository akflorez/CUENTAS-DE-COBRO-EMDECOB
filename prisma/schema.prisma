generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Invoice {
  id                String        @id @default(cuid())
  consecutivo       String        @unique
  conjuntoNombre    String
  asesor            String?
  portafolio        String        @default("PROPIEDAD HORIZONTAL")
  estadoCobro       String?
  capitalTotal      Float
  interesesTotal    Float
  honorariosTotal   Float
  ivaTotal          Float
  granTotal         Float
  status            String        @default("PENDIENTE")
  fechaPago         DateTime?
  fechaIngresoPorte DateTime?
  fechaElaboracion  DateTime?
  gestionMes        Int?
  gestionAnio       Int?
  generacionMes     Int?
  generacionAnio    Int?
  validadoTesoreria Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  montoPagado       Float         @default(0)
  observacion       String?       @default("")
  items             InvoiceItem[]
  payments          Payment[]
}

model InvoiceItem {
  id                String  @id @default(cuid())
  invoiceId         String
  fechaPago         String?
  fechaIngresoPorte String?
  fechaElaboracion  String?
  predio            String
  capital    Float
  intereses  Float
  honorarios Float
  iva        Float
  total      Float
  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  monto       Float
  tipo        String   // RECAUDO, CRUCE_ANTICIPO, DESCUENTO, AJUSTE
  fecha       DateTime @default(now())
  metodo      String?
  observacion String?  @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}
