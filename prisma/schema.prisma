// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Invoice {
  id              String   @id @default(cuid())
  consecutivo     String   @unique
  conjuntoNombre  String
  asesor          String?
  estadoCobro     String?  
  
  capitalTotal    Float
  interesesTotal  Float
  honorariosTotal Float
  ivaTotal        Float
  granTotal       Float

  items           InvoiceItem[]

  // Campos de gestión nuevos
  status          String    @default("PENDIENTE") // PENDIENTE, PAGADA o ANULADA
  montoPagado     Float     @default(0)
  fechaPago       DateTime?
  validadoTesoreria Boolean @default(false)
  observacion String? @default("")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  fechaPago   String?
  predio      String
  capital     Float
  intereses   Float
  honorarios  Float
  iva         Float
  total       Float
}
